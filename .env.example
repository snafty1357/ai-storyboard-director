# AI Storyboard Director - API Keys Configuration
# このファイルを .env.local にコピーして、実際のAPIキーを設定してください

# ===========================================
# OpenAI / GPT Image 2
# ===========================================
# GPT Image 2 を使用したキーフレーム画像生成用
# https://platform.openai.com/api-keys から取得
OPENAI_API_KEY=your_openai_api_key_here


# ===========================================
# fal.ai (Seedance 2.0)
# ===========================================
# Seedance 2.0 を fal.ai 経由で使用
# https://fal.ai/dashboard/keys から取得
FAL_KEY=your_fal_api_key_here

# ===========================================
# Optional Settings
# ===========================================
# 生成設定（オプション）
NEXT_PUBLIC_DEFAULT_ASPECT_RATIO=16:9
NEXT_PUBLIC_DEFAULT_GENRE=cinematic
